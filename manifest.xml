<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<OfficeApp
    xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
    xmlns:mailappor="http://schemas.microsoft.com/office/mailappversionoverrides/1.0"
    xsi:type="MailApp">

  <!-- Identificador único de la aplicación. NO cambiar (rompe instalaciones existentes). -->
  <Id>9b5a0e2f-3c7a-4d8e-9b1f-firma3digital04</Id>

  <!-- Versión del manifest. Incrementar a cada release para forzar actualización. -->
  <Version>3.0.4.0</Version>

  <ProviderName>Intelec S.L.</ProviderName>
  <DefaultLocale>es-ES</DefaultLocale>

  <DisplayName DefaultValue="Firma Digital"/>
  <Description DefaultValue="Aplica firma digital criptográfica PKCS#7 SHA-256 a PDFs adjuntos en correo Outlook con detección automática de campos y vista previa interactiva."/>

  <!-- Iconos en distintas resoluciones. Outlook elegirá el adecuado. -->
  <IconUrl DefaultValue="https://intelecsl.github.io/intelec-firma/icons/icon-64.png"/>
  <HighResolutionIconUrl DefaultValue="https://intelecsl.github.io/intelec-firma/icons/icon-128.png"/>

  <!-- URL desde la que se actualizará el manifest automáticamente. -->
  <SupportUrl DefaultValue="https://intelecsl.github.io/intelec-firma/"/>
  <AppDomains>
    <AppDomain>https://intelecsl.github.io</AppDomain>
    <AppDomain>https://cdnjs.cloudflare.com</AppDomain>
    <AppDomain>https://appsforoffice.microsoft.com</AppDomain>
  </AppDomains>

  <Hosts>
    <Host Name="Mailbox"/>
  </Hosts>

  <Requirements>
    <Sets>
      <Set Name="Mailbox" MinVersion="1.5"/>
    </Sets>
  </Requirements>

  <FormSettings>
    <Form xsi:type="ItemRead">
      <DesktopSettings>
        <SourceLocation DefaultValue="https://intelecsl.github.io/intelec-firma/index.html"/>
        <RequestedHeight>450</RequestedHeight>
      </DesktopSettings>
    </Form>
  </FormSettings>

  <Permissions>ReadWriteMailbox</Permissions>

  <Rule xsi:type="RuleCollection" Mode="Or">
    <Rule xsi:type="ItemIs" ItemType="Message" FormType="Read"/>
  </Rule>

  <DisableEntityHighlighting>false</DisableEntityHighlighting>

  <!-- Overrides v1.1: añade botón en la cinta del Outlook moderno -->
  <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides" xsi:type="VersionOverridesV1_0">
    <Requirements>
      <bt:Sets DefaultMinVersion="1.3">
        <bt:Set Name="Mailbox"/>
      </bt:Sets>
    </Requirements>

    <Hosts>
      <Host xsi:type="MailHost">
        <DesktopFormFactor>
          <FunctionFile resid="Commands.Url"/>

          <ExtensionPoint xsi:type="MessageReadCommandSurface">
            <OfficeTab id="TabDefault">
              <Group id="firmaIntelecGroup">
                <Label resid="GroupLabel"/>
                <Control xsi:type="Button" id="firmaIntelecButton">
                  <Label resid="ButtonLabel"/>
                  <Supertip>
                    <Title resid="ButtonTitle"/>
                    <Description resid="ButtonDescription"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon16"/>
                    <bt:Image size="32" resid="Icon32"/>
                    <bt:Image size="80" resid="Icon80"/>
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <SourceLocation resid="Taskpane.Url"/>
                    <SupportsPinning>true</SupportsPinning>
                  </Action>
                </Control>
              </Group>
            </OfficeTab>
          </ExtensionPoint>
        </DesktopFormFactor>
      </Host>
    </Hosts>

    <Resources>
      <bt:Images>
        <bt:Image id="Icon16" DefaultValue="https://intelecsl.github.io/intelec-firma/icons/icon-16.png"/>
        <bt:Image id="Icon32" DefaultValue="https://intelecsl.github.io/intelec-firma/icons/icon-32.png"/>
        <bt:Image id="Icon80" DefaultValue="https://intelecsl.github.io/intelec-firma/icons/icon-80.png"/>
      </bt:Images>
      <bt:Urls>
        <bt:Url id="Commands.Url" DefaultValue="https://intelecsl.github.io/intelec-firma/index.html"/>
        <bt:Url id="Taskpane.Url" DefaultValue="https://intelecsl.github.io/intelec-firma/index.html"/>
      </bt:Urls>
      <bt:ShortStrings>
        <bt:String id="GroupLabel" DefaultValue="Intelec"/>
        <bt:String id="ButtonLabel" DefaultValue="Firma Digital"/>
        <bt:String id="ButtonTitle" DefaultValue="Firma Digital Intelec"/>
      </bt:ShortStrings>
      <bt:LongStrings>
        <bt:String id="ButtonDescription" DefaultValue="Firma criptográfica PKCS#7 de PDFs adjuntos."/>
      </bt:LongStrings>
    </Resources>
  </VersionOverrides>

</OfficeApp>
