{
  "$schema": "https://developer.microsoft.com/json-schemas/teams/v1.24/MicrosoftTeams.schema.json",
  "id": "45296c6e-05b2-45fe-b01d-9173d54288a7",
  "manifestVersion": "1.24",
  "version": "3.1.2",
  "name": {
    "short": "Firma Digital",
    "full": "Firma Digital Intelec"
  },
  "description": {
    "short": "Firma criptografica PKCS7 SHA-256 de PDFs adjuntos.",
    "full": "Aplica firma digital criptografica PKCS7 SHA-256 a PDFs adjuntos en correo Outlook, con deteccion automatica de campos AcroForm, vista previa interactiva con click-to-place y persistencia del certificado."
  },
  "developer": {
    "name": "Intelec S.L.",
    "websiteUrl": "https://intelecsl.github.io/intelec-firma/",
    "privacyUrl": "https://intelecsl.github.io/intelec-firma/",
    "termsOfUseUrl": "https://intelecsl.github.io/intelec-firma/"
  },
  "icons": {
    "outline": "assets/outline.png",
    "color": "assets/color.png"
  },
  "accentColor": "#e8f03a",
  "localizationInfo": {
    "defaultLanguageTag": "es-es",
    "additionalLanguages": []
  },
  "authorization": {
    "permissions": {
      "resourceSpecific": [
        {
          "name": "MailboxItem.Read.User",
          "type": "Delegated"
        }
      ]
    }
  },
  "validDomains": [
    "intelecsl.github.io"
  ],
  "extensions": [
    {
      "requirements": {
        "scopes": [ "mail" ]
      },
      "runtimes": [
        {
          "requirements": {
            "capabilities": [
              { "name": "Mailbox", "minVersion": "1.5" }
            ]
          },
          "id": "TaskPaneRuntimeMail",
          "type": "general",
          "code": {
            "page": "https://intelecsl.github.io/intelec-firma/index.html"
          },
          "lifetime": "short",
          "actions": [
            {
              "id": "TaskPaneRuntimeShowMail",
              "type": "openPage",
              "pinnable": true
            }
          ]
        }
      ],
      "ribbons": [
        {
          "requirements": {
            "capabilities": [
              { "name": "Mailbox", "minVersion": "1.5" }
            ]
          },
          "contexts": [ "mailRead" ],
          "tabs": [
            {
              "builtInTabId": "TabDefault",
              "groups": [
                {
                  "id": "firmaIntelecGroup",
                  "label": "Firma Digital",
                  "icons": [
                    { "size": 16, "url": "https://intelecsl.github.io/intelec-firma/assets/icon-16.png" },
                    { "size": 32, "url": "https://intelecsl.github.io/intelec-firma/assets/icon-32.png" },
                    { "size": 80, "url": "https://intelecsl.github.io/intelec-firma/assets/icon-80.png" }
                  ],
                  "controls": [
                    {
                      "id": "firmaIntelecButton",
                      "type": "button",
                      "label": "Firma Digital",
                      "icons": [
                        { "size": 16, "url": "https://intelecsl.github.io/intelec-firma/assets/icon-16.png" },
                        { "size": 32, "url": "https://intelecsl.github.io/intelec-firma/assets/icon-32.png" },
                        { "size": 80, "url": "https://intelecsl.github.io/intelec-firma/assets/icon-80.png" }
                      ],
                      "supertip": {
                        "title": "Firma Digital Intelec",
                        "description": "Firma criptografica PKCS7 de PDFs adjuntos."
                      },
                      "actionId": "TaskPaneRuntimeShowMail"
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
