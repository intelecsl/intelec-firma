{
  "$schema": "https://developer.microsoft.com/json-schemas/teams/v1.17/MicrosoftTeams.schema.json",
  "manifestVersion": "1.17",
  "id": "9b5a0e2f-3c7a-4d8e-9b1f-firma3digital04",
  "version": "3.0.4",
  "name": {
    "short": "Firma Digital",
    "full": "Firma Digital Intelec"
  },
  "description": {
    "short": "Firma criptográfica PKCS#7 de PDFs adjuntos.",
    "full": "Aplica firma digital criptográfica PKCS#7 SHA-256 a PDFs adjuntos en correo Outlook con detección automática de campos AcroForm, vista previa interactiva con click-to-place, y persistencia del certificado en el navegador."
  },
  "developer": {
    "name": "Intelec S.L.",
    "websiteUrl": "https://intelecsl.github.io/intelec-firma/",
    "privacyUrl": "https://intelecsl.github.io/intelec-firma/",
    "termsOfUseUrl": "https://intelecsl.github.io/intelec-firma/"
  },
  "icons": {
    "color": "icons/icon-128.png",
    "outline": "icons/icon-32.png"
  },
  "accentColor": "#e8f03a",
  "validDomains": [
    "intelecsl.github.io",
    "cdnjs.cloudflare.com"
  ],
  "authorization": {
    "permissions": {
      "resourceSpecific": [
        {
          "name": "MailboxItem.Read.User",
          "type": "Delegated"
        }
      ]
    }
  },
  "extensions": [
    {
      "requirements": {
        "scopes": ["mail"],
        "capabilities": [
          { "name": "Mailbox", "minVersion": "1.5" }
        ]
      },
      "ribbons": [
        {
          "contexts": ["mailRead"],
          "tabs": [
            {
              "builtInTabId": "TabDefault",
              "groups": [
                {
                  "id": "firmaIntelecGroup",
                  "label": "Intelec",
                  "controls": [
                    {
                      "id": "firmaIntelecButton",
                      "type": "button",
                      "label": "Firma Digital",
                      "icons": [
                        { "size": 16, "url": "icons/icon-16.png" },
                        { "size": 32, "url": "icons/icon-32.png" },
                        { "size": 80, "url": "icons/icon-80.png" }
                      ],
                      "supertip": {
                        "title": "Firma Digital Intelec",
                        "description": "Firma criptográfica PKCS#7 de PDFs adjuntos."
                      },
                      "actionId": "openFirmaTaskpane"
                    }
                  ]
                }
              ]
            }
          ]
        }
      ],
      "actions": [
        {
          "id": "openFirmaTaskpane",
          "type": "openPage",
          "view": "firmaTaskpane"
        }
      ],
      "runtimes": [
        {
          "requirements": {
            "capabilities": [
              { "name": "Mailbox", "minVersion": "1.5" }
            ]
          },
          "id": "TaskPaneRuntime",
          "type": "general",
          "code": {
            "page": "https://intelecsl.github.io/intelec-firma/index.html"
          },
          "lifetime": "short",
          "actions": [
            {
              "id": "openFirmaTaskpane",
              "type": "openPage",
              "pinnable": true,
              "view": "firmaTaskpane"
            }
          ]
        }
      ],
      "alternates": [
        {
          "alternateIcons": {
            "icon": {
              "size": 64,
              "url": "https://intelecsl.github.io/intelec-firma/icons/icon-64.png"
            },
            "highResolutionIcon": {
              "size": 128,
              "url": "https://intelecsl.github.io/intelec-firma/icons/icon-128.png"
            }
          }
        }
      ]
    }
  ]
}
