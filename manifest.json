{
  "$schema": "https://developer.microsoft.com/json-schemas/teams/v1.17/MicrosoftTeams.schema.json",
  "manifestVersion": "1.17",
  "id": "45296c6e-05b2-45fe-b01d-9173d54288a7",
  "version": "3.0.5",
  "name": {
    "short": "Firma Digital",
    "full": "Firma Digital Intelec"
  },
  "description": {
    "short": "Firma criptografica PKCS7 de PDFs adjuntos.",
    "full": "Aplica firma digital criptografica PKCS7 SHA-256 a PDFs adjuntos en correo Outlook con deteccion automatica de campos AcroForm, vista previa interactiva con click-to-place, y persistencia del certificado en el navegador."
  },
  "developer": {
    "name": "Intelec S.L.",
    "websiteUrl": "https://intelecsl.github.io/intelec-firma/",
    "privacyUrl": "https://intelecsl.github.io/intelec-firma/",
    "termsOfUseUrl": "https://intelecsl.github.io/intelec-firma/"
  },
  "icons": {
    "color": "color.png",
    "outline": "outline.png"
  },
  "accentColor": "#e8f03a",
  "localizationInfo": {
    "defaultLanguageTag": "es-ES"
  },
  "authorization": {
    "permissions": {
      "resourceSpecific": [
        {
          "name": "MailboxItem.Read.User",
          "type": "Delegated"
        }
      ]
    }
  },
  "validDomains": [
    "intelecsl.github.io"
  ],
  "extensions": [
    {
      "requirements": {
        "scopes": [
          "mail"
        ],
        "capabilities": [
          {
            "name": "Mailbox",
            "minVersion": "1.5"
          }
        ]
      },
      "ribbons": [
        {
          "contexts": [
            "mailRead"
          ],
          "tabs": [
            {
              "builtInTabId": "TabDefault",
              "groups": [
                {
                  "id": "firmaIntelecGroup",
                  "label": "Intelec",
                  "controls": [
                    {
                      "id": "firmaIntelecButton",
                      "type": "button",
                      "label": "Firma Digital",
                      "icons": [
                        {
                          "size": 16,
                          "file": "icon-16.png"
                        },
                        {
                          "size": 32,
                          "file": "icon-32.png"
                        },
                        {
                          "size": 80,
                          "file": "icon-80.png"
                        }
                      ],
                      "supertip": {
                        "title": "Firma Digital Intelec",
                        "description": "Firma criptografica PKCS7 de PDFs adjuntos."
                      },
                      "actionId": "openFirmaTaskpane"
                    }
                  ]
                }
              ]
            }
          ]
        }
      ],
      "runtimes": [
        {
          "requirements": {
            "capabilities": [
              {
                "name": "Mailbox",
                "minVersion": "1.5"
              }
            ]
          },
          "id": "TaskPaneRuntime",
          "type": "general",
          "code": {
            "page": "https://intelecsl.github.io/intelec-firma/index.html"
          },
          "lifetime": "short",
          "actions": [
            {
              "id": "openFirmaTaskpane",
              "type": "openPage",
              "pinnable": true,
              "view": "firmaTaskpane"
            }
          ]
        }
      ]
    }
  ]
}
